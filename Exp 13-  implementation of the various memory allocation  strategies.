#include <stdio.h>

void firstFit(int block[], int m, int process[], int n) {
    int alloc[n];

    for (int i = 0; i < n; i++) {
        alloc[i] = -1;

        for (int j = 0; j < m; j++) {
            if (block[j] >= process[i]) {
                alloc[i] = j;
                block[j] -= process[i];
                break;
            }
        }
    }

    printf("\nFirst Fit Allocation:\n");
    for (int i = 0; i < n; i++)
        printf("Process %d -> Block %d\n", i + 1, alloc[i] + 1);
}

void bestFit(int block[], int m, int process[], int n) {
    int alloc[n];

    for (int i = 0; i < n; i++) {
        alloc[i] = -1;
        int best = -1;

        for (int j = 0; j < m; j++) {
            if (block[j] >= process[i]) {
                if (best == -1 || block[j] < block[best])
                    best = j;
            }
        }

        if (best != -1) {
            alloc[i] = best;
            block[best] -= process[i];
        }
    }

    printf("\nBest Fit Allocation:\n");
    for (int i = 0; i < n; i++)
        printf("Process %d -> Block %d\n", i + 1, alloc[i] + 1);
}

void worstFit(int block[], int m, int process[], int n) {
    int alloc[n];

    for (int i = 0; i < n; i++) {
        alloc[i] = -1;
        int worst = -1;

        for (int j = 0; j < m; j++) {
            if (block[j] >= process[i]) {
                if (worst == -1 || block[j] > block[worst])
                    worst = j;
            }
        }

        if (worst != -1) {
            alloc[i] = worst;
            block[worst] -= process[i];
        }
    }

    printf("\nWorst Fit Allocation:\n");
    for (int i = 0; i < n; i++)
        printf("Process %d -> Block %d\n", i + 1, alloc[i] + 1);
}

int main() {
    int m, n;

    int block[10], process[10];

    printf("Enter number of memory blocks: ");
    scanf("%d", &m);

    printf("Enter block sizes:\n");
    for (int i = 0; i < m; i++)
        scanf("%d", &block[i]);

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter process sizes:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &process[i]);

    int b1[10], b2[10], b3[10];

    for (int i = 0; i < m; i++) {
        b1[i] = block[i];
        b2[i] = block[i];
        b3[i] = block[i];
    }

    firstFit(b1, m, process, n);
    bestFit(b2, m, process, n);
    worstFit(b3, m, process, n);

    return 0;
}
