#include <stdio.h>

int mutex = 1;
int full = 0;
int empty = 3, x = 0;

void producer() {
    mutex--;
    full++;
    empty--;
    x++;
    printf("Producer produces item %d\n", x);
    mutex++;
}

void consumer() {
    mutex--;
    full--;
    empty++;
    printf("Consumer consumes item %d\n", x);
    x--;
    mutex++;
}

int main() {
    int n, i;

    printf("Enter number of operations: ");
    scanf("%d", &n);

    for(i = 1; i <= n; i++) {
        int choice;
        printf("\n1. Produce\n2. Consume\n3. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                if((mutex == 1) && (empty != 0))
                    producer();
                else
                    printf("Buffer is Full!\n");
                break;

            case 2:
                if((mutex == 1) && (full != 0))
                    consumer();
                else
                    printf("Buffer is Empty!\n");
                break;

            case 3:
                return 0;

            default:
                printf("Invalid Choice\n");
        }
    }
    return 0;
}
