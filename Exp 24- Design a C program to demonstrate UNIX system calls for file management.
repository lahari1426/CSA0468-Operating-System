#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int fd;
    char data[] = "Hello, UNIX File Management!";
    char buffer[100];

    fd = open("sample.txt", O_CREAT | O_WRONLY, 0644);

    write(fd, data, sizeof(data));
    close(fd);

    fd = open("sample.txt", O_RDONLY);

    read(fd, buffer, sizeof(buffer));

    printf("File Content: %s\n", buffer);

    close(fd);

    return 0;
}
