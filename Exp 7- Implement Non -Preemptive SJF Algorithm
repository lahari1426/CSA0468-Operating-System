#include <stdio.h>

int main() {
    int n, i, j, bt[10], temp;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter burst times:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &bt[i]);

    // Sort burst times in ascending order
    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(bt[i] > bt[j]) {
                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;
            }
        }
    }

    printf("\nExecution Order:\n");
    for(i = 0; i < n; i++)
        printf("P%d (%d) ", i + 1, bt[i]);

    return 0;
}
