#include <fcntl.h>
#include <unistd.h>

int main() {
    int src, dest;
    char buf[100];
    int n;

    src = open("source.txt", O_RDONLY);
    dest = open("dest.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);

    while ((n = read(src, buf, sizeof(buf))) > 0)
        write(dest, buf, n);

    close(src);
    close(dest);

    return 0;
}
